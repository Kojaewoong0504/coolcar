# Supabase — current hosted key names
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Supabase — legacy/Next aliases also supported by the app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase direct DB management
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASS=
SUPABASE_DB_PROJECT_NAME=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External APIs — both TMAP names are supported
TMAP_APPKEY=
TMAP_APP_KEY=
SEOUL_OPEN_API_KEY=
SEOUL_OPENAPI_KEY=
SEOUL_OPENAPI_LIVE_ENABLED=false
SEOUL_OPENAPI_TIMEOUT_MS=1500
SEOUL_REALTIME_SUBWAY_API_KEY=
SEOUL_SUBWAY_REALTIME_API_KEY=
SEOUL_REALTIME_SUBWAY_ENABLED=false
SEOUL_REALTIME_SUBWAY_BASE_URL=http://swopenAPI.seoul.go.kr/api/subway
KMA_API_KEY=

# TMAP diagnostics
TMAP_CONGESTION_ENDPOINT=https://apis.openapi.sk.com/puzzle/subway/congestion/stat/car/stations
TMAP_TIMEOUT_MS=3500
TMAP_CACHE_TTL_SECONDS=21600
# 월 10회 무료 quota 보호: 기본은 외부 TMAP live 호출 금지. true로 켤 때만 실제 호출.
TMAP_LIVE_ENABLED=false
TMAP_CACHE_ONLY=true
TMAP_DIAGNOSTICS_ENABLED=false
TMAP_DIAGNOSTICS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Support reports — server-only values, do not expose with NEXT_PUBLIC_
SUPPORT_REPORTS_MAX_BODY_BYTES=32768
SUPPORT_REPORTS_MAX_MESSAGE_CHARS=2000
SUPPORT_REPORTS_IP_HASH_SECRET=
SUPPORT_REPORTS_DISCORD_ENABLED=false
SUPPORT_REPORTS_DISCORD_WEBHOOK_URL=

# Optional AI batch only; not used in realtime recommendation
OPENAI_API_KEY=
AI_BATCH_MODEL=

# Toss Apps in Toss future
NEXT_PUBLIC_RUNTIME=web
TOSS_APP_ID=
